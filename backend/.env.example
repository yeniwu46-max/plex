# ============ Flask 环境 ============
# 环境: development (开发) | testing (测试) | production (生产)
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=True

# ============ 数据库配置 ============
# MySQL 连接字符串
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/learning_system

# MySQL 连接详情（可选，备选方案）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=learning_system

# ============ JWT 认证密钥 ============
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-generate-it-yourself
JWT_SECRET_KEY=your-jwt-secret-key-generate-it-yourself

# ============ JWT 配置 ============
# Token过期时间（小时）
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============ 服务器配置 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ============ AI 能力配置 ============
# 阿里百炼 API
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_MODEL=deepseek-v3

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============ CORS 配置 ============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ 环境标记 ============
# 用于区分不同环境（可选）
ENVIRONMENT=development
VERSION=1.0.0
